# ============================================================
# AGENTMONEY - CONFIGURAÇÃO DE AMBIENTE
# Modo: DEMO/SIMULAÇÃO ou PRODUÇÃO
# ============================================================

# ============================================================
# MODO DE OPERAÇÃO
# ============================================================
AGENTMONEY_MODE=demo
AGENTMONEY_LOG_LEVEL=INFO

# ============================================================
# API KEYS - OPENAI / GPT
# ============================================================
OPENAI_API_KEY=sk-demo-key-replace-in-production
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# API KEYS - MÚSICA IA (Suno / Udio)
# ============================================================
SUNO_API_KEY=suno-demo-key
UDIO_API_KEY=udio-demo-key

# ============================================================
# API KEYS - IMAGEM IA (Thumbnails)
# ============================================================
# NOTA: Midjourney NAO tem API publica (Discord apenas)
# RECOMENDADO: DALL-E 3 (voce ja tem OpenAI configurada!)
STABILITY_API_KEY=stability-demo-key

# ============================================================
# YOUTUBE API - OAuth2
# ============================================================
YOUTUBE_CLIENT_ID=your-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-client-secret
YOUTUBE_REFRESH_TOKEN=your-refresh-token
YOUTUBE_CHANNEL_ID=your-channel-id

# ============================================================
# TIKTOK API
# ============================================================
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token
TIKTOK_OPEN_ID=your-tiktok-open-id

# ============================================================
# INSTAGRAM GRAPH API
# ============================================================
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_ACCOUNT_ID=your-instagram-account-id
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret

# ============================================================
# FACEBOOK GRAPH API
# ============================================================
FACEBOOK_ACCESS_TOKEN=your-facebook-access-token
FACEBOOK_PAGE_ID=your-facebook-page-id
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ============================================================
# KWAI OPEN API
# ============================================================
KWAI_ACCESS_TOKEN=your-kwai-access-token
KWAI_APP_ID=your-kwai-app-id
KWAI_APP_SECRET=your-kwai-app-secret

# ============================================================
# SHOPEE AFFILIATE API
# ============================================================
SHOPEE_AFFILIATE_ID=your-affiliate-id
SHOPEE_AFFILIATE_TOKEN=your-affiliate-token
SHOPEE_APP_KEY=your-app-key
SHOPEE_APP_SECRET=your-app-secret
SHOPEE_REGION=BR

# ============================================================
# SHOPEE CREDENCIAIS (Browser Automation)
# ============================================================
SHOPEE_USERNAME=your-shopee-username
SHOPEE_PASSWORD=your-shopee-password
SHOPEE_COOKIES_PATH=data/shopee_cookies.json

# ============================================================
# REDES SOCIAIS - API TOKENS
# ============================================================
TELEGRAM_BOT_TOKEN=telegram-bot-token
TELEGRAM_CHANNEL_ID=@seucanal
WHATSAPP_API_KEY=whatsapp-api-key
FACEBOOK_ACCESS_TOKEN=fb-access-token
INSTAGRAM_ACCESS_TOKEN=ig-access-token

# ============================================================
# CONFIGURAÇÕES DE PRODUÇÃO
# ============================================================
# Limite de produtos para análise diária
SHOPEE_DAILY_PRODUCT_LIMIT=10
# Limite de vídeos para produção diária
YOUTUBE_DAILY_VIDEO_LIMIT=1
# Diretório de assets
ASSETS_DIR=assets
# Diretório de dados
DATA_DIR=data
# Diretório de logs
LOGS_DIR=logs

# ============================================================
# BROWSER AUTOMATION (Playwright/Selenium)
# ============================================================
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000
BROWSER_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

# ============================================================
# BANCO DE DADOS (SQLite para demo, PostgreSQL para prod)
# ============================================================
DATABASE_URL=sqlite:///data/agentmoney.db
# DATABASE_URL=postgresql://user:pass@localhost/agentmoney

# ============================================================
# WEBHOOKS E NOTIFICAÇÕES
# ============================================================
WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
NOTIFY_ON_ERROR=true
NOTIFY_ON_SUCCESS=true
